# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ──────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ───────────────────────────────────────────────────
/.next/
/out/
/build

# ── Testing ───────────────────────────────────────────────────
/coverage

# ── Environment ───────────────────────────────────────────────
# All .env files EXCEPT .env.example (template for devs)
.env
.env.*
!.env.example

# ── Database ──────────────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
/prisma/migrations/

# ── Prisma generated client ──────────────────────────────────
/src/generated/prisma

# ── Scripts (seed/migration — dev only) ───────────────────────
/scripts/

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── IDE / Editor ──────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.bak

# ── Logs ──────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── Security / keys ──────────────────────────────────────────
*.pem
*.key
*.crt
*.p12

# ── TypeScript cache ─────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ────────────────────────────────────────────────────
.vercel

# ── Temp / misc ──────────────────────────────────────────────
/tmp/
*.tmp
*.temp