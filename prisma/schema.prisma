generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       Int
  category    String   @default("engine")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
