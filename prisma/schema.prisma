generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       Int
  category    String   @default("engine")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  name        String
  phone       String
  date        String?
  services    String   // Store as JSON string
  totalPrice  Int
  status      String   @default("NEW")
}
