generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Service {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  price       Int
  isActive    Boolean   @default(true)
  categoryId  Int? // For relation
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String // e.g. "Ремонт двигателя"
  slug     String    @unique // e.g. "engine"
  services Service[] // Relation back to services
}

model Booking {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  name       String
  phone      String
  date       String?
  services   String // Store as JSON string
  totalPrice Int
  status     String   @default("NEW")
  carBrand   String? // Марка автомобиля
  carPlate   String? // Государственный номер
  comment    String? // Доп. информация / пожелания
}

model PromoEvent {
  id             Int      @id @default(autoincrement())
  title          String   @default("Бесплатная диагностика")
  description    String?  @default("Запишитесь на бесплатную диагностику вашего автомобиля")
  isActive       Boolean  @default(false)
  eventDateStart String? // Дата начала акции ("2026-03-01")
  eventDate      String? // Дата окончания акции ("2026-03-31")
  updatedAt      DateTime @updatedAt
}

model VideoReview {
  id          Int      @id @default(autoincrement())
  youtubeUrl  String // Ссылка на YouTube видео
  description String? // "Отзыв от Ивана, владельца ВАЗ-21214, клиент с 2015 года"
  reviewDate  String // Отображаемая дата ("2025-03-01"), сортировка по ней
  createdAt   DateTime @default(now())
}
