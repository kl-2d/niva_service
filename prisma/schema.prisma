generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       Int
  isActive    Boolean  @default(true)
  categoryId  Int?     // For relation
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    // e.g. "Ремонт двигателя"
  slug        String    @unique // e.g. "engine"
  services    Service[] // Relation back to services
}

model Booking {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  name        String
  phone       String
  date        String?
  services    String   // Store as JSON string
  totalPrice  Int
  status      String   @default("NEW")
  carBrand    String?  // Марка автомобиля
  carPlate    String?  // Государственный номер
}
